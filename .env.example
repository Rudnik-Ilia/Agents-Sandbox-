# Ollama connection and models. Copy to .env and adjust as needed.
OLLAMA_BASE_URL=http://10.100.102.10:11434
LLM_MODEL=gemma4:e4b
EMBED_MODEL=mxbai-embed-large:latest

# Generation. The first call may cold-load a large model, so the timeout is high.
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=600
LLM_KEEP_ALIVE=30m
# Context window (tokens) passed to Ollama; console shows usage against this.
LLM_NUM_CTX=8192
# Thinking/reasoning mode. false = off (faster, no chain-of-thought).
LLM_THINK=false

# Retrieval
RAG_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Reranker backend (rag-rerank): cross-encoder model + fused candidate pool size.
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FUSION_CANDIDATES=12

# Reliability: fall back to this model and retry on errors/timeouts.
FALLBACK_MODEL=llama3.1:8b
LLM_MAX_RETRIES=2

# Safety: require confirmation before dangerous tools (e.g. shell) run.
REQUIRE_TOOL_APPROVAL=true

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_DIR=logs

# Observability: LangSmith tracing (set true + API key to enable).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=localagent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
